{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@venueflow/booking-engine": ["../../packages/booking-engine/src/index.ts"],
      "@venueflow/booking-engine/styles": ["../../packages/booking-engine/src/styles/booking-engine.css"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "../../packages/booking-engine/src/**/*.ts", "../../packages/booking-engine/src/**/*.tsx"],
  "exclude": ["node_modules"]
}
